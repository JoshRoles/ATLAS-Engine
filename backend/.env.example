# Optional — public market data works without keys; keys increase Binance rate-limit weight.
# Create a READ-ONLY API key on Binance (no trading / withdrawal permissions).
BINANCE_API_KEY=
BINANCE_SECRET=

# CORS: your deployed frontend origin(s), comma-separated. Use * only for local dev.
# Example: https://atlas-engine.vercel.app
CORS_ORIGINS=*
